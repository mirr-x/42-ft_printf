{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",                // 👈 this must match launch.json
            "type": "shell",
            "command": "gcc",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "main.c",
                "libftprintf.a",
                "-o",
                "main"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}
